layout {
    gaps 4

    center-focused-column "on-overflow"
    always-center-single-column

    default-column-width { proportion 0.64; }

    preset-column-widths {
        proportion 0.64
        proportion 0.96
    }

    preset-window-heights {
        proportion 0.5
        proportion 1.0
    }

    focus-ring { off; }

    border {
        on
        width 1
    }
}
